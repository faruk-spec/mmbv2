# ============================================================
# WhatsApp Bridge — Environment Configuration
# ============================================================
# Copy this file to .env and fill in the values.
# The bridge reads this file automatically when it starts.
#
# HOW TO USE:
#   cp .env.example .env
#   nano .env          ← set your values
#   ../restart-bridge.sh
# ============================================================

# ── Server binding (defaults below are fine for most setups) ──
PORT=3000
HOST=0.0.0.0

# ── Proxy (REQUIRED if curl https://web.whatsapp.com fails) ──
#
# If you get "SSL error" or "timeout" when the bridge tries to
# connect to WhatsApp, you need a proxy server located in a
# country/datacenter where WhatsApp is accessible.
#
# Options:
#   SOCKS5 proxy (recommended):
#     WHATSAPP_PROXY_URL=socks5://USERNAME:PASSWORD@HOST:PORT
#
#   HTTP/HTTPS proxy:
#     WHATSAPP_PROXY_URL=http://USERNAME:PASSWORD@HOST:PORT
#
# Examples (replace with real values):
#     WHATSAPP_PROXY_URL=socks5://alice:secret@proxy.example.com:1080
#     WHATSAPP_PROXY_URL=http://user:pass@123.45.67.89:3128
#     WHATSAPP_PROXY_URL=socks5://123.45.67.89:1080    (no auth)
#
# Leave blank / commented out if the server can reach WhatsApp directly.
# WHATSAPP_PROXY_URL=

# ── Baileys browser identification ──────────────────────────
# WhatsApp identifies the client by its browser string.
# Only change this if you are told to by a Baileys update.
# BAILEYS_BROWSER_VERSION=124.0.0
